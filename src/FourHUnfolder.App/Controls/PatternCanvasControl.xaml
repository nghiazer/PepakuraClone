<UserControl x:Class="FourHUnfolder.App.Controls.PatternCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Compact icon-only button for 2D toolbar — icons enlarged ×1.4, rounded corners -->
        <Style x:Key="Icon2D" TargetType="Button">
            <Setter Property="Padding"   Value="6,4"/>
            <Setter Property="Margin"    Value="1"/>
            <Setter Property="MinWidth"  Value="32"/>
            <Setter Property="FontSize"  Value="19"/>
            <Setter Property="Cursor"    Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Toggle2D" TargetType="ToggleButton">
            <Setter Property="Padding"   Value="6,4"/>
            <Setter Property="Margin"    Value="1"/>
            <Setter Property="MinWidth"  Value="32"/>
            <Setter Property="FontSize"  Value="19"/>
            <Setter Property="Cursor"    Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconBtnPressedBg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Canvas2DBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable canvas area + zoom indicator overlay -->
        <Grid Grid.Row="0">
            <ScrollViewer x:Name="Scroller"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden"
                          Background="{DynamicResource Canvas2DScrollerBg}"
                          PreviewMouseWheel="Scroller_PreviewMouseWheel"
                          PreviewMouseDown="Scroller_PreviewMouseDown"
                          PreviewMouseMove="Scroller_PreviewMouseMove"
                          PreviewMouseUp="Scroller_PreviewMouseUp">
                <Canvas x:Name="RootCanvas"
                        Background="Transparent"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonDown="Canvas_LeftDown"
                        MouseLeftButtonUp="Canvas_MouseUp"
                        MouseLeave="Canvas_MouseUp"/>
            </ScrollViewer>

            <!-- Zoom level badge (top-right, non-interactive) -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,6,8,0" Padding="5,2"
                    Background="{DynamicResource Canvas2DZoomBadgeBg}" CornerRadius="3" IsHitTestVisible="False">
                <TextBlock x:Name="ZoomLabel" Text="3.0 px/mm"
                           Foreground="{DynamicResource TextMuted}" FontSize="10"/>
            </Border>
        </Grid>

        <!-- Bottom toolbar — icon-only compact buttons -->
        <Border Grid.Row="1" Background="{DynamicResource Toolbar2DBg}" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource Icon2D}" Content="⟲" Click="RotateCCW_Click"
                        ToolTip="Rotate –90°"/>
                <Button Style="{StaticResource Icon2D}" Content="⟳" Click="RotateCW_Click"
                        ToolTip="Rotate +90°"/>
                <Separator Margin="4,0"/>
                <!-- F5: Alignment buttons (visible only when 2+ pieces selected) -->
                <Button Style="{StaticResource Icon2D}" Content="◧" Click="AlignLeft_Click"
                        ToolTip="Align selected pieces — Left edges"/>
                <Button Style="{StaticResource Icon2D}" Content="◫" Click="AlignCenterV_Click"
                        ToolTip="Align selected pieces — Center vertically"/>
                <Button Style="{StaticResource Icon2D}" Content="◨" Click="AlignRight_Click"
                        ToolTip="Align selected pieces — Right edges"/>
                <Button Style="{StaticResource Icon2D}" Content="⊤" Click="AlignTop_Click"
                        ToolTip="Align selected pieces — Top edges"/>
                <Button Style="{StaticResource Icon2D}" Content="⊥" Click="AlignBottom_Click"
                        ToolTip="Align selected pieces — Bottom edges"/>
                <Button Style="{StaticResource Icon2D}" Content="↔" Click="AlignCenterH_Click"
                        ToolTip="Align selected pieces — Center horizontally"/>
                <Separator Margin="4,0"/>
                <Button Style="{StaticResource Icon2D}" Content="✦" Click="AutoArrange_Click"
                        ToolTip="Auto-arrange pieces"/>
                <Separator Margin="4,0"/>
                <ToggleButton Style="{StaticResource Toggle2D}" x:Name="RotatePointBtn"
                              Content="⊙" Click="RotatePoint_Click"
                              ToolTip="Rotate by Point — click vertex=pivot, click another=handle, mouse to rotate"/>
                <ToggleButton Style="{StaticResource Toggle2D}" x:Name="EditEdgesBtn"
                              Content="✏" Click="EditEdges_Click"
                              ToolTip="Edit Edges — hover to highlight, left-click to attach/detach"/>
                <Separator Margin="4,0"/>
                <ToggleButton Style="{StaticResource Toggle2D}" x:Name="GridToggleBtn"
                              Content="⊞"
                              IsChecked="{Binding GridVisible, Mode=OneWay}"
                              Click="GridToggle_Click"
                              ToolTip="Toggle grid"/>
                <ToggleButton Style="{StaticResource Toggle2D}" x:Name="SnapToggleBtn"
                              Content="⊟"
                              IsChecked="{Binding SnapToGrid, Mode=OneWay}"
                              Click="SnapToggle_Click"
                              ToolTip="Snap to grid when dragging"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
