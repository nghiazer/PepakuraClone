<UserControl x:Class="FourHUnfolder.App.Controls.PatternCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#3a3a5a">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable canvas area + zoom indicator overlay -->
        <Grid Grid.Row="0">
            <ScrollViewer x:Name="Scroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#2a2a4a"
                          PreviewMouseWheel="Scroller_PreviewMouseWheel">
                <Canvas x:Name="RootCanvas"
                        Background="Transparent"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonDown="Canvas_LeftDown"
                        MouseLeftButtonUp="Canvas_MouseUp"
                        MouseLeave="Canvas_MouseUp"/>
            </ScrollViewer>

            <!-- Zoom level badge (top-right, non-interactive) -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,6,24,0" Padding="6,2"
                    Background="#99000022" CornerRadius="3" IsHitTestVisible="False">
                <TextBlock x:Name="ZoomLabel" Text="3.0 px/mm"
                           Foreground="#aaaacc" FontSize="11"/>
            </Border>
        </Grid>

        <!-- Bottom toolbar -->
        <Border Grid.Row="1" Background="#1a1a30" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="⟲ –90°" Click="RotateCCW_Click"
                        Padding="8,3" Margin="2" Cursor="Hand"
                        ToolTip="Rotate selected piece(s) 90° counter-clockwise"/>
                <Button Content="⟳ +90°" Click="RotateCW_Click"
                        Padding="8,3" Margin="2" Cursor="Hand"
                        ToolTip="Rotate selected piece(s) 90° clockwise"/>
                <Separator Margin="8,0"/>
                <Button Content="✦ Auto-arrange" Click="AutoArrange_Click"
                        Padding="8,3" Margin="2" Cursor="Hand"
                        ToolTip="Pack all pieces onto the paper automatically"/>
                <Separator Margin="8,0"/>
                <ToggleButton x:Name="RotatePointBtn"
                              Content="⊙ Rotate Point"
                              Click="RotatePoint_Click"
                              Padding="8,3" Margin="2" Cursor="Hand"
                              ToolTip="Toggle rotate-by-point mode: click a vertex to set pivot, click another to start rotating"/>
                <ToggleButton x:Name="EditEdgesBtn"
                              Content="✏ Edit Edges"
                              Click="EditEdges_Click"
                              Padding="8,3" Margin="2" Cursor="Hand"
                              ToolTip="Toggle edge-edit mode: hover to highlight, left-click to attach/detach pieces"/>
                <Separator Margin="8,0"/>
                <ToggleButton x:Name="GridToggleBtn"
                              Content="⊞ Grid"
                              IsChecked="{Binding GridVisible, Mode=OneWay}"
                              Click="GridToggle_Click"
                              Padding="8,3" Margin="2" Cursor="Hand"
                              ToolTip="Show / hide the grid"/>
                <ToggleButton x:Name="SnapToggleBtn"
                              Content="⊟ Snap"
                              IsChecked="{Binding SnapToGrid, Mode=OneWay}"
                              Click="SnapToggle_Click"
                              Padding="8,3" Margin="2" Cursor="Hand"
                              ToolTip="Snap pieces to grid when dragging"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
