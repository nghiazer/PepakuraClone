<Window x:Class="FourHUnfolder.App.Dialogs.TextureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Texture" Width="360" Height="170"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e3c" Foreground="White">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Thumbnail -->
        <Border Grid.Row="0" Grid.RowSpan="3" Width="48" Height="48"
                BorderBrush="#555577" BorderThickness="1" CornerRadius="3"
                Background="#111122" ClipToBounds="True" VerticalAlignment="Top">
            <Grid>
                <Rectangle>
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#555566" Geometry="M0,0 H8 V8 H0 Z"/>
                                    <GeometryDrawing Brush="#333344" Geometry="M0,0 H4 V4 H0 Z M4,4 H8 V8 H4 Z"/>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Image Source="{Binding ActiveTextureThumbnail}" Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="No texture" Foreground="#666688" FontSize="8"
                           TextWrapping="Wrap" TextAlignment="Center"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Visibility="{Binding NoTexturePlaceholderVisible}"/>
            </Grid>
        </Border>

        <!-- Status row -->
        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="TEXTURE" Foreground="#6666aa" FontSize="9" FontWeight="Bold"/>
            <TextBlock Text="{Binding TextureStatusText}" Foreground="#c8d8ff" FontSize="12"
                       FontWeight="SemiBold" MaxWidth="260" TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="🎨  Load" Command="{Binding LoadTextureCommand}"
                    Padding="9,5" Margin="0,0,6,0" Cursor="Hand"/>
            <Button Content="✖  Remove" Command="{Binding RemoveTextureCommand}"
                    IsEnabled="{Binding CanRemoveTexture}"
                    Padding="9,5" Cursor="Hand"/>
        </StackPanel>

        <!-- Preview confirm row (only visible when preview active) -->
        <Border Grid.Column="1" Grid.Row="2"
                Background="#3a2800" BorderBrush="Orange" BorderThickness="1"
                CornerRadius="4" Padding="8,4"
                Visibility="{Binding PreviewBadgeVisible}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚡ PREVIEW" Foreground="Orange" FontWeight="Bold" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="✔ Apply" Command="{Binding ApplyPreviewCommand}"
                        Background="#1a4a1a" Foreground="#90ee90" BorderBrush="#2a8a2a"
                        Padding="8,4" Margin="0,0,4,0" Cursor="Hand"/>
                <Button Content="✖ Cancel" Command="{Binding CancelPreviewCommand}"
                        Background="#4a1a1a" Foreground="#ff9090" BorderBrush="#8a2a2a"
                        Padding="8,4" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
