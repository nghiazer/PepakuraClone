<Window x:Class="FourHUnfolder.App.Dialogs.ModelOrientationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="Model Orientation"
        Width="560" Height="480"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{DynamicResource DialogBg}" Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FieldLabelFg}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Height"      Value="26"/>
            <Setter Property="Width"       Value="80"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="{DynamicResource CheckBoxFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title -->
            <RowDefinition Height="*"/>     <!-- viewer + controls -->
            <RowDefinition Height="Auto"/>  <!-- flip uv -->
            <RowDefinition Height="Auto"/>  <!-- don't ask again -->
            <RowDefinition Height="Auto"/>  <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- ── Title ───────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Set Model Orientation"
                       FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="The viewport shows your model with the selected orientation applied (live preview). Axis lines: Red=+X, Green=+Y, Blue=+Z."
                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Mesh viewer + axis selectors ─────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>       <!-- mesh preview -->
                <ColumnDefinition Width="180"/>     <!-- controls -->
            </Grid.ColumnDefinitions>

            <!-- Mesh preview viewport.
                 Axis lines (X=Red, Y=Green, Z=Blue) and the actual mesh
                 are added in code-behind. The mesh rotates live as you change axes. -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderNormal}" BorderThickness="1" CornerRadius="4"
                    Margin="0,0,12,0">
                <Grid>
                    <helix:HelixViewport3D x:Name="CubeViewport"
                                           Background="#0d0d1a"
                                           ShowCoordinateSystem="False"
                                           ShowViewCube="False">
                        <helix:HelixViewport3D.Camera>
                            <PerspectiveCamera Position="3,2.5,3"
                                               LookDirection="-1,-0.8,-1"
                                               UpDirection="0,1,0"
                                               FieldOfView="50"/>
                        </helix:HelixViewport3D.Camera>
                        <helix:DefaultLights/>
                        <!-- mesh + axis lines added programmatically in code-behind -->
                    </helix:HelixViewport3D>

                    <!-- TD-27-2: 2D axis label overlay — positions updated in code-behind -->
                    <Canvas x:Name="AxisLabelCanvas" IsHitTestVisible="False">
                        <TextBlock x:Name="LabelX" Text="+X"
                                   Foreground="#ff5555" FontSize="11" FontWeight="Bold"
                                   Canvas.Left="0" Canvas.Top="0"/>
                        <TextBlock x:Name="LabelY" Text="+Y"
                                   Foreground="#44cc44" FontSize="11" FontWeight="Bold"
                                   Canvas.Left="0" Canvas.Top="0"/>
                        <TextBlock x:Name="LabelZ" Text="+Z"
                                   Foreground="#5599ff" FontSize="11" FontWeight="Bold"
                                   Canvas.Left="0" Canvas.Top="0"/>
                    </Canvas>

                    <TextBlock Text="Drag to rotate view" Foreground="{DynamicResource TextMuted}" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ── Axis selector controls ────────────────── -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Axis Reference" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                           FontSize="12" Margin="0,0,0,8"/>

                <!-- Axis color legend matching the 3D lines -->
                <StackPanel Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="4" Fill="#ff4444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+X axis (Red)" Style="{StaticResource Label}" Margin="0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="4" Fill="#44cc44" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+Y axis (Green)" Style="{StaticResource Label}" Margin="0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="4" Fill="#4488ff" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+Z axis (Blue)" Style="{StaticResource Label}" Margin="0"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="{DynamicResource BorderNormal}" Margin="0,0,0,12"/>

                <!-- Up axis -->
                <TextBlock Text="Up axis (maps to world +Y)"
                           Style="{StaticResource Label}" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AxisOptions}"
                          SelectedItem="{Binding UpAxis}"
                          ToolTip="Which axis of your model should point upward in the world?"
                          Margin="0,0,0,12"/>

                <!-- Front axis -->
                <TextBlock Text="Front axis (maps to world +Z)"
                           Style="{StaticResource Label}" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding AxisOptions}"
                          SelectedItem="{Binding FrontAxis}"
                          ToolTip="Which axis of your model should face forward?"
                          Margin="0,0,0,8"/>

                <!-- TD-27-3: parallel-axes warning -->
                <TextBlock Text="⚠ Up and Front must be different axes!"
                           Foreground="#ff6666" FontSize="10" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AxesAreParallel}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- ── Flip UV ──────────────────────────────── -->
        <Border Grid.Row="2" Background="{DynamicResource DialogNavBg}" CornerRadius="4" Padding="10,8" Margin="0,12,0,0">
            <StackPanel>
                <CheckBox Content="Flip UV (mirror texture vertically)"
                          IsChecked="{Binding FlipUV}"
                          ToolTip="Flips V coordinate: fixes textures that appear upside-down."/>
                <TextBlock Text="Tip: if the texture looks wrong after loading, try enabling Flip UV."
                           Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="20,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Don't ask again ─────────────────────── -->
        <!-- TD-25-1: persisted to AppSettings.General.SkipModelOrientationDialog -->
        <CheckBox x:Name="ChkDontAskAgain"
                  Grid.Row="3"
                  Content="Don't ask again (always load with current settings)"
                  Margin="0,10,0,0"
                  IsChecked="False"
                  ToolTip="Suppresses this dialog on future loads. Reset via Settings → General."/>

        <!-- ── Buttons ──────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <!-- TD-27-3: disable OK when axes are parallel -->
            <Button Content="  OK  " Width="80" Height="30"
                    Background="{DynamicResource BtnOkBg}"
                    Foreground="{DynamicResource BtnOkFg}"
                    BorderBrush="{DynamicResource BtnOkBorder}"
                    Cursor="Hand" Margin="0,0,8,0" Click="OK_Click" IsDefault="True">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AxesAreParallel}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity"   Value="0.35"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Skip" Width="80" Height="30"
                    Background="{DynamicResource CtrlBtnBg}"
                    Foreground="{DynamicResource TextMuted}"
                    BorderBrush="{DynamicResource BorderNormal}"
                    Cursor="Hand" Click="Skip_Click" IsCancel="True"
                    ToolTip="Skip orientation adjustment and load mesh as-is"/>
        </StackPanel>
    </Grid>
</Window>
