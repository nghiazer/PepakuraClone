<Window x:Class="FourHUnfolder.App.Dialogs.ModelOrientationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="Model Orientation"
        Width="600" Height="500"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{DynamicResource DialogBg}" Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <Style x:Key="FieldLabelLocal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FieldLabelFg}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"     Value="0,0,8,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Height"      Value="26"/>
            <Setter Property="Width"       Value="80"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="{DynamicResource CheckBoxFg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title -->
            <RowDefinition Height="*"/>     <!-- viewer + controls -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Title ───────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Set Model Orientation"
                       FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="The viewport shows your model with the selected orientation applied (live preview). Axis lines: Red=+X, Green=+Y, Blue=+Z."
                       Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Mesh viewer + axis selectors ─────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>   <!-- mesh preview ~60% -->
                <ColumnDefinition Width="2*"/>   <!-- controls ~40% -->
            </Grid.ColumnDefinitions>

            <!-- Mesh preview viewport -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderNormal}" BorderThickness="1" CornerRadius="4"
                    Margin="0,0,12,0">
                <Grid>
                    <helix:HelixViewport3D x:Name="CubeViewport"
                                           Background="#0d0d1a"
                                           ShowCoordinateSystem="False"
                                           ShowViewCube="False">
                        <helix:HelixViewport3D.Camera>
                            <PerspectiveCamera Position="3,2.5,3"
                                               LookDirection="-1,-0.8,-1"
                                               UpDirection="0,1,0"
                                               FieldOfView="50"/>
                        </helix:HelixViewport3D.Camera>
                        <helix:DefaultLights/>
                        <!-- mesh + axis lines added programmatically in code-behind -->
                    </helix:HelixViewport3D>

                    <!-- 2D axis label overlay — positions updated in code-behind -->
                    <Canvas x:Name="AxisLabelCanvas" IsHitTestVisible="False">
                        <TextBlock x:Name="LabelX" Text="+X"
                                   Foreground="#ff5555" FontSize="11" FontWeight="Bold"
                                   Canvas.Left="0" Canvas.Top="0"/>
                        <TextBlock x:Name="LabelY" Text="+Y"
                                   Foreground="#44cc44" FontSize="11" FontWeight="Bold"
                                   Canvas.Left="0" Canvas.Top="0"/>
                        <TextBlock x:Name="LabelZ" Text="+Z"
                                   Foreground="#5599ff" FontSize="11" FontWeight="Bold"
                                   Canvas.Left="0" Canvas.Top="0"/>
                    </Canvas>

                    <TextBlock Text="Drag to rotate view" Foreground="{DynamicResource TextMuted}" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- ── Axis selector controls ────────────────── -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">

                <!-- Axis Reference heading -->
                <TextBlock Text="AXIS REFERENCE" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}"
                           FontSize="10" Margin="0,0,0,8"
                           TextWrapping="Wrap" Height="Auto"/>

                <!-- Axis color legend -->
                <StackPanel Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="4" Fill="#ff4444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+X axis (Red)" Style="{StaticResource FieldLabelLocal}" Margin="0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="4" Fill="#44cc44" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+Y axis (Green)" Style="{StaticResource FieldLabelLocal}" Margin="0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <Rectangle Width="14" Height="4" Fill="#4488ff" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="+Z axis (Blue)" Style="{StaticResource FieldLabelLocal}" Margin="0"/>
                    </StackPanel>
                </StackPanel>

                <Separator Background="{DynamicResource BorderNormal}" Margin="0,0,0,12"/>

                <!-- Up axis -->
                <TextBlock Text="Up axis (maps to world +Y)"
                           Style="{StaticResource FieldLabelLocal}" Margin="0,0,0,4"
                           TextWrapping="Wrap"/>
                <ComboBox ItemsSource="{Binding AxisOptions}"
                          SelectedItem="{Binding UpAxis}"
                          ToolTip="Which axis of your model should point upward in the world?"
                          Margin="0,0,0,12"/>

                <!-- Front axis -->
                <TextBlock Text="Front axis (maps to world +Z)"
                           Style="{StaticResource FieldLabelLocal}" Margin="0,0,0,4"
                           TextWrapping="Wrap"/>
                <ComboBox ItemsSource="{Binding AxisOptions}"
                          SelectedItem="{Binding FrontAxis}"
                          ToolTip="Which axis of your model should face forward?"
                          Margin="0,0,0,4"/>

                <!-- Parallel-axes warning -->
                <TextBlock Text="⚠ Up and Front must be different axes!"
                           Foreground="{DynamicResource WarningTextFg}" FontSize="10" TextWrapping="Wrap"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AxesAreParallel}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Separator Background="{DynamicResource BorderNormal}" Margin="0,0,0,12"/>

                <!-- Flip UV — moved here from separate row, no background box -->
                <CheckBox Content="Flip UV (mirror texture vertically)"
                          IsChecked="{Binding FlipUV}"
                          ToolTip="Flips V coordinate: fixes textures that appear upside-down."
                          Margin="0,0,0,4"/>
                <TextBlock Text="Tip: if the texture looks wrong after loading, try enabling Flip UV."
                           Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="20,0,0,0"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Grid>

        <!-- ── Footer: Don't-ask-again left / buttons right ── -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="ChkDontAskAgain"
                      Grid.Column="0"
                      Content="Don't ask again (always load with current settings)"
                      VerticalAlignment="Center"
                      IsChecked="False"
                      ToolTip="Suppresses this dialog on future loads. Reset via Settings → General."/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- Import = primary action, accent style -->
                <Button Content="Import" Width="80" Height="34"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="{DynamicResource BtnOkBg}"
                        Foreground="{DynamicResource BtnOkFg}"
                        BorderBrush="{DynamicResource BtnOkBorder}"
                        Cursor="Hand" Margin="0,0,8,0" Click="OK_Click" IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AxesAreParallel}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity"   Value="0.35"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- Cancel = neutral secondary -->
                <Button Content="Cancel" Width="80" Height="34"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="{DynamicResource CtrlBtnBg}"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource BorderNormal}"
                        Cursor="Hand" Click="Cancel_Click" IsCancel="True"
                        ToolTip="Cancel and go back without applying orientation"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
