<Window x:Class="FourHUnfolder.App.Dialogs.UnfoldSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unfold Setup"
        Width="440" Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBg}"
        Foreground="{DynamicResource TextPrimary}">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground"  Value="{DynamicResource FieldLabelFg}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource InputBorder}"/>
            <Setter Property="Padding"                  Value="4,0"/>
            <Setter Property="Height"                   Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource InputFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="Height"      Value="26"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"  Value="{DynamicResource GroupBoxFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GroupBoxBorder}"/>
            <Setter Property="Margin"      Value="0,0,0,10"/>
            <Setter Property="Padding"     Value="10,8"/>
        </Style>
        <!-- Dim style for locked custom-size inputs -->
        <Style x:Key="CustomInput" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- ═══ Model Dimensions ════════════════════════════════════ -->
        <GroupBox DockPanel.Dock="Top" Header="Model Dimensions (Real World Scale)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <!-- Bounding box info -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                           x:Name="BBoxLabel"
                           Text="Bounding box: —"
                           Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>

                <!-- Scale fields -->
                <Label Grid.Row="2" Grid.Column="0" Content="Scale axis :"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          x:Name="AxisCombo"
                          SelectedIndex="3"
                          Margin="0,0,6,0">
                    <ComboBoxItem>Width  (X)</ComboBoxItem>
                    <ComboBoxItem>Height (Y)</ComboBoxItem>
                    <ComboBoxItem>Depth  (Z)</ComboBoxItem>
                    <ComboBoxItem>Longest axis</ComboBoxItem>
                </ComboBox>
                <TextBox  Grid.Row="2" Grid.Column="2"
                          x:Name="TargetSizeBox"
                          Text="200" Margin="0,0,6,0"/>
                <ComboBox Grid.Row="2" Grid.Column="3"
                          x:Name="UnitCombo"
                          SelectedIndex="0">
                    <ComboBoxItem>mm</ComboBoxItem>
                    <ComboBoxItem>cm</ComboBoxItem>
                    <ComboBoxItem>inch</ComboBoxItem>
                </ComboBox>
            </Grid>
        </GroupBox>

        <!-- ═══ Paper Size ══════════════════════════════════════════ -->
        <GroupBox DockPanel.Dock="Top" Header="Paper Size">
            <!-- Unified 2-column grid: label (Auto) | control (*) -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Row 0: Preset -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Row 2: Orientation -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- Row 4: Custom Size -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>  <!-- label -->
                    <ColumnDefinition Width="*"/>    <!-- control -->
                </Grid.ColumnDefinitions>

                <!-- Row 0: Preset -->
                <Label Grid.Row="0" Grid.Column="0" Content="Preset :"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          x:Name="PaperPresetCombo"
                          SelectionChanged="PaperPreset_Changed">
                    <ComboBoxItem>A4   (210 × 297 mm)</ComboBoxItem>
                    <ComboBoxItem>A3   (297 × 420 mm)</ComboBoxItem>
                    <ComboBoxItem>A2   (420 × 594 mm)</ComboBoxItem>
                    <ComboBoxItem>A1   (594 × 841 mm)</ComboBoxItem>
                    <ComboBoxItem>Letter (215.9 × 279.4 mm)</ComboBoxItem>
                    <ComboBoxItem>Legal  (215.9 × 355.6 mm)</ComboBoxItem>
                    <ComboBoxItem>Custom …</ComboBoxItem>
                </ComboBox>

                <!-- Row 2: Orientation -->
                <Label Grid.Row="2" Grid.Column="0" Content="Orientation :"/>
                <StackPanel Grid.Row="2" Grid.Column="1"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="PortraitRadio"
                                 Content="Portrait"  IsChecked="True"
                                 Foreground="{DynamicResource TextPrimary}" Margin="0,0,18,0"/>
                    <RadioButton x:Name="LandscapeRadio"
                                 Content="Landscape"
                                 Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <!-- Row 4: Custom Size (mm) — locked unless Preset=Custom -->
                <Label Grid.Row="4" Grid.Column="0" Content="Custom Size (mm) :"/>
                <StackPanel Grid.Row="4" Grid.Column="1"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="CustomWidthBox"
                             Style="{StaticResource CustomInput}"
                             Text="210" Width="70" Margin="0,0,4,0"
                             IsEnabled="False"/>
                    <TextBlock Text="×" VerticalAlignment="Center"
                               Foreground="{DynamicResource FieldLabelFg}"
                               FontSize="13" Margin="0,0,4,0"/>
                    <TextBox x:Name="CustomHeightBox"
                             Style="{StaticResource CustomInput}"
                             Text="297" Width="70"
                             IsEnabled="False"/>
                </StackPanel>

            </Grid>
        </GroupBox>

        <!-- ═══ Buttons ══════════════════════════════════════════════ -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,6,0,0">
            <Button Content="OK"
                    Width="80" Height="34" Margin="0,0,10,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{DynamicResource BtnOkBg}"
                    Foreground="{DynamicResource BtnOkFg}"
                    BorderBrush="{DynamicResource BtnOkBorder}"
                    Click="OK_Click"/>
            <Button Content="Cancel"
                    Width="80" Height="34"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{DynamicResource BtnCancelBg}"
                    Foreground="{DynamicResource BtnCancelFg}"
                    BorderBrush="{DynamicResource BtnCancelBorder}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
