<Window x:Class="FourHUnfolder.App.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:FourHUnfolder.App.Converters"
        Title="Settings"
        Width="720" Height="580"
        MinWidth="620" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e3c" Foreground="White">

    <Window.Resources>
        <conv:HexColorBrushConverter x:Key="HexBrush"/>

        <!-- Nav item style -->
        <Style x:Key="NavItem" TargetType="ListBoxItem">
            <Setter Property="Padding"          Value="14,10"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Foreground"       Value="#aabbd0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2a2a5a"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22224a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section GroupBox style -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"   Value="#a0c0ff"/>
            <Setter Property="BorderBrush"  Value="#3a3a60"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="Padding"      Value="10,8"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"           Value="#c0d0f0"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="Margin"               Value="0,0,8,0"/>
        </Style>

        <!-- Input TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#12122b"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#555577"/>
            <Setter Property="Padding"      Value="4,3"/>
            <Setter Property="Height"       Value="26"/>
        </Style>

        <!-- Slider style (subtle) -->
        <Style x:Key="SettingSlider" TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width"             Value="140"/>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="#c0d0f0"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,4"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="#12122b"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#555577"/>
            <Setter Property="Height"       Value="26"/>
            <Setter Property="Width"        Value="160"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left nav ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="#12122b"
                BorderBrush="#2a2a4a" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="SETTINGS" Foreground="#444466"
                           FontSize="9" FontWeight="Bold" Margin="14,14,0,8"/>
                <ListBox x:Name="NavList"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎲" FontSize="15" Margin="0,0,8,0"/>
                            <TextBlock Text="3D View" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="15" Margin="0,0,8,0"/>
                            <TextBlock Text="2D View" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖨" FontSize="15" Margin="0,0,8,0"/>
                            <TextBlock Text="Print / Export" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavItem}" Tag="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="15" Margin="0,0,8,0"/>
                            <TextBlock Text="General" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- ═══ Right content ════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="0" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12">
            <!-- Single Grid child — all panels share the same cell and toggle Visibility -->
            <Grid>

            <!-- ── 3D View Panel ──────────────────────────────────── -->
            <StackPanel x:Name="Panel3D">
                <TextBlock Text="3D View" FontSize="18" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,14"/>

                <!-- Background & chrome -->
                <GroupBox Header="Viewport">
                    <StackPanel>
                        <!-- Color row template (reused via copy) -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Background color"
                                       Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding Background3D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource InputBox}"
                                     Text="{Binding Background3D, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="9" ToolTip="#AARRGGBB or #RRGGBB"/>
                        </Grid>

                        <CheckBox Content="Show coordinate system"
                                  IsChecked="{Binding ShowCoordSystem}"/>
                        <CheckBox Content="Show view cube"
                                  IsChecked="{Binding ShowViewCube}"/>
                    </StackPanel>
                </GroupBox>

                <!-- Mesh appearance -->
                <GroupBox Header="Mesh Appearance">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Display mode" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DisplayModes}"
                                      SelectedItem="{Binding DisplayMode3D}"/>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Face color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding FaceColor3D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding FaceColor3D, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Back-face color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding BackFaceColor3D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding BackFaceColor3D, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Face opacity" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0" Maximum="1"
                                    Value="{Binding FaceOpacity}" TickFrequency="0.1"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FaceOpacity, StringFormat={}{0:F2}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Camera -->
                <GroupBox Header="Camera">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Field of view (°)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="5" Maximum="120" TickFrequency="5"
                                    Value="{Binding CameraFOV}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CameraFOV, StringFormat={}{0:F0}°}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Near clip plane" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.001" Maximum="5" Value="{Binding CameraNearPlane}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CameraNearPlane, StringFormat={}{0:F3}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Far clip plane" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="100" Maximum="100000" Value="{Binding CameraFarPlane}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CameraFarPlane, StringFormat={}{0:F0}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Edge overlay (active when SolidEdges mode) -->
                <GroupBox Header="Edge Overlay  (active when Display Mode = SolidEdges)">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Edge color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding EdgeOverlayColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding EdgeOverlayColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Edge thickness" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.1" Maximum="3"
                                    Value="{Binding EdgeOverlayThickness}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding EdgeOverlayThickness, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- 3D Edge Edit Mode -->
                <GroupBox Header="3D Edge Edit Mode  (hover an edge → LMB to detach/attach)">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Detachable edge color" Style="{StaticResource FieldLabel}"
                                       ToolTip="Color shown when hovering over a fold edge that can be detached (made into a cut)"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding EdgeHoverDetachColor3D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding EdgeHoverDetachColor3D, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Attachable edge color" Style="{StaticResource FieldLabel}"
                                       ToolTip="Color shown when hovering over a cut edge that can be re-attached (made into a fold)"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding EdgeHoverAttachColor3D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding EdgeHoverAttachColor3D, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Lighting -->
                <GroupBox Header="Lighting">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ambient intensity" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0" Maximum="1"
                                    Value="{Binding AmbientIntensity}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AmbientIntensity, StringFormat={}{0:F2}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Directional intensity" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0" Maximum="2"
                                    Value="{Binding DirectionalIntensity}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DirectionalIntensity, StringFormat={}{0:F2}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- ── 2D View Panel ──────────────────────────────────── -->
            <StackPanel x:Name="Panel2D" Visibility="Collapsed">
                <TextBlock Text="2D View" FontSize="18" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,14"/>

                <GroupBox Header="Canvas">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Canvas background" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding CanvasBackground, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding CanvasBackground, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Paper color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding PaperColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding PaperColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Default zoom (px/mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.5" Maximum="10"
                                    Value="{Binding DefaultPixelsPerMm}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DefaultPixelsPerMm, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Grid">
                    <StackPanel>
                        <CheckBox Content="Show grid" IsChecked="{Binding ShowGrid}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Grid color (ARGB)" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding GridColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding GridColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Grid spacing (mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="1" Maximum="50"
                                    Value="{Binding GridSizeMm}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GridSizeMm, StringFormat={}{0:F0}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Face Fill">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Face fill color (ARGB)" Style="{StaticResource FieldLabel}"/>
                        <Rectangle Grid.Column="1" Width="22" Height="22"
                                   Fill="{Binding FaceFillColor, Converter={StaticResource HexBrush}}"
                                   Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                 Text="{Binding FaceFillColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Fold Edges">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fold line color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding FoldLineColor2D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding FoldLineColor2D, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fold line width" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.3" Maximum="4"
                                    Value="{Binding FoldLineWidth2D}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FoldLineWidth2D, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fold line dash" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DashPatterns}"
                                      SelectedItem="{Binding FoldLineDash2D}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Cut Edges">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cut line color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding CutLineColor2D, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding CutLineColor2D, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cut line width" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.3" Maximum="4"
                                    Value="{Binding CutLineWidth2D}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding CutLineWidth2D, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Edge Edit Mode">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Edge hover highlight color" Style="{StaticResource FieldLabel}"/>
                        <Rectangle Grid.Column="1" Width="22" Height="22"
                                   Fill="{Binding EdgeHoverColor, Converter={StaticResource HexBrush}}"
                                   Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                 Text="{Binding EdgeHoverColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Paper Size">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Default paper size" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding PaperSizeNames}"
                                  SelectedItem="{Binding DefaultPaperSizeName}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Piece Layout">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Gap between pieces (mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0" Maximum="30" Value="{Binding PieceGapMm}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PieceGapMm, StringFormat={}{0:F0}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <CheckBox Content="Snap pieces to grid when dragging"
                                  IsChecked="{Binding SnapToGrid}"
                                  ToolTip="When enabled, piece centroids snap to the nearest grid intersection while dragging"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Glue Tabs &amp; Annotations">
                    <StackPanel>
                        <CheckBox Content="Show glue tabs" IsChecked="{Binding ShowGlueTabs}"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Glue tab color (ARGB)" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding GlueTabColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding GlueTabColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <CheckBox Content="Show face numbers" IsChecked="{Binding ShowFaceNumbers}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Edge ID Labels  (assembly numbering on cut edges)">
                    <StackPanel>
                        <CheckBox Content="Show edge ID numbers on cut edges"
                                  IsChecked="{Binding ShowEdgeIds}"
                                  ToolTip="Displays matching pair numbers on cut edges so you know which edges to glue together"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Edge ID color (ARGB)" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding EdgeIdColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding EdgeIdColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- ── Print Panel ────────────────────────────────────── -->
            <StackPanel x:Name="PanelPrint" Visibility="Collapsed">
                <TextBlock Text="Print / Export" FontSize="18" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,14"/>

                <GroupBox Header="Page Layout">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Page margin (mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0" Maximum="40"
                                    Value="{Binding MarginMm}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding MarginMm, StringFormat={}{0:F0}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bleed (mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0" Maximum="10"
                                    Value="{Binding BleedMm}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding BleedMm, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SVG scale (px per mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="1" Maximum="30"
                                    Value="{Binding SvgScaleFactor}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding SvgScaleFactor, StringFormat={}{0:F0}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Glue Tab Geometry">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tab shape" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TabShapes}"
                                      SelectedItem="{Binding GlueTabShape}"
                                      ToolTip="Trapezoid = inset corners; Rectangle = full-width; Triangle = pointed tip"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tab depth (mm)" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="1" Maximum="20"
                                    Value="{Binding GlueTabDepthMm}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GlueTabDepthMm, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Side wall angle (°)" Style="{StaticResource FieldLabel}"
                                       ToolTip="Angle of tab side walls vs. edge. 90°=rectangle, 45°=default trapezoid, lower=sharper taper. Applies to Trapezoid shape."/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="1" Maximum="90" TickFrequency="1"
                                    Value="{Binding GlueTabSideAngleDeg}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GlueTabSideAngleDeg, StringFormat={}{0:F0}°}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <CheckBox Content="Alternate flap placement"
                                  IsChecked="{Binding AlternateFlaps}"
                                  ToolTip="Only one face per cut edge pair gets a tab — halves the total number of tabs, making assembly cleaner"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Content">
                    <StackPanel>
                        <CheckBox Content="Include glue tabs"      IsChecked="{Binding IncludeGlueTabs}"/>
                        <CheckBox Content="Print fold lines"       IsChecked="{Binding PrintFoldLines}"/>
                        <CheckBox Content="Print cut lines"        IsChecked="{Binding PrintCutLines}"/>
                        <CheckBox Content="Include page label"     IsChecked="{Binding IncludePageLabel}"/>
                        <CheckBox Content="Grayscale output"       IsChecked="{Binding GrayscaleOutput}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Fold Lines (Print)">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fold line color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding PrintFoldColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding PrintFoldColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fold line width" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.3" Maximum="4" Value="{Binding PrintFoldWidth}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PrintFoldWidth, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Fold line dash" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DashPatterns}"
                                      SelectedItem="{Binding PrintFoldDash}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Cut Lines (Print)">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cut line color" Style="{StaticResource FieldLabel}"/>
                            <Rectangle Grid.Column="1" Width="22" Height="22"
                                       Fill="{Binding PrintCutColor, Converter={StaticResource HexBrush}}"
                                       Stroke="#666" StrokeThickness="1" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="2" Style="{StaticResource InputBox}"
                                     Text="{Binding PrintCutColor, UpdateSourceTrigger=PropertyChanged}" MaxLength="9"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cut line width" Style="{StaticResource FieldLabel}"/>
                            <Slider Grid.Column="1" Style="{StaticResource SettingSlider}"
                                    Minimum="0.3" Maximum="4" Value="{Binding PrintCutWidth}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PrintCutWidth, StringFormat={}{0:F1}}"
                                       Foreground="#aaaacc" VerticalAlignment="Center" Margin="6,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- ── General Panel ──────────────────────────────────── -->
            <StackPanel x:Name="PanelGeneral" Visibility="Collapsed">
                <TextBlock Text="General" FontSize="18" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,14"/>

                <GroupBox Header="Display">
                    <StackPanel>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Display unit" Style="{StaticResource FieldLabel}"
                                       ToolTip="Unit used when showing dimensions in the UI"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DisplayUnits}"
                                      SelectedItem="{Binding DisplayUnit}"
                                      Width="120"
                                      ToolTip="mm = millimetres, inch = inches — affects all dimension labels in the app"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            </Grid><!-- end single-child Grid -->
        </ScrollViewer>

        <!-- ═══ Footer ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#12122b"
                BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Button Content="↺  Reset to defaults"
                        HorizontalAlignment="Left"
                        Width="160" Height="30"
                        Background="#3a2020" Foreground="#ffaaaa" BorderBrush="#6a3030"
                        Click="Reset_Click" Cursor="Hand"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="  OK  " Width="80" Height="30"
                            Background="#1a4060" Foreground="White" BorderBrush="#2a6090"
                            Margin="0,0,8,0" Click="OK_Click" Cursor="Hand"/>
                    <Button Content="Apply" Width="80" Height="30"
                            Background="#1a3a20" Foreground="White" BorderBrush="#2a6a30"
                            Margin="0,0,8,0" Click="Apply_Click" Cursor="Hand"/>
                    <Button Content="Cancel" Width="80" Height="30"
                            Background="#402020" Foreground="White" BorderBrush="#804040"
                            Click="Cancel_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
