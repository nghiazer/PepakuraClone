<Window x:Class="FourHUnfolder.App.Dialogs.AssemblyAnimationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        Title="Assembly Animation — Step-by-Step Fold Guide"
        Width="900" Height="700"
        MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBg}">

    <Window.Resources>
        <!-- Button style matching the main toolbar -->
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Padding"    Value="14,6"/>
            <Setter Property="Margin"     Value="3,0"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="MinWidth"   Value="38"/>
            <Setter Property="Background" Value="{DynamicResource CtrlBtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource CtrlBtnFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CtrlBtnBorder}"/>
        </Style>

        <Style x:Key="PlayBtn" TargetType="Button" BasedOn="{StaticResource CtrlBtn}">
            <Setter Property="Background" Value="{DynamicResource BtnApplyBg}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="MinWidth"   Value="100"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BtnCancelBg}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Legend dot indicator -->
        <Style x:Key="LegendDot" TargetType="Ellipse">
            <Setter Property="Width"   Value="10"/>
            <Setter Property="Height"  Value="10"/>
            <Setter Property="Margin"  Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- 0: 3-D viewport (full height, no overlay) -->
            <RowDefinition Height="Auto"/>   <!-- 1: thin progress bar -->
            <RowDefinition Height="Auto"/>   <!-- 2: step timeline slider -->
            <RowDefinition Height="Auto"/>   <!-- 3: control toolbar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0 — 3-D Viewport (clean, no overlay) ════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BorderNormal}" BorderThickness="0,0,0,1">
            <helix:HelixViewport3D x:Name="Viewport3D"
                                   Background="#0d0d1a"
                                   ShowCoordinateSystem="True"
                                   ShowViewCube="True"
                                   ZoomAroundMouseDownPoint="True">
                <helix:DefaultLights/>
                <ModelVisual3D Content="{Binding AssemblyModel}"/>
            </helix:HelixViewport3D>
        </Border>

        <!-- ═══ Row 1 — Thin progress bar ═══════════════════════════════════ -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding StepProgress, Mode=OneWay}"
                     Maximum="100"
                     Height="4"
                     Background="{DynamicResource AssemblyStepBg}"
                     Foreground="#ffcc30"
                     BorderThickness="0"/>

        <!-- ═══ Row 2 — Step timeline slider ════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource AssemblyStepBg}" Padding="12,6">
            <Slider Minimum="0"
                    Maximum="{Binding StepMaxIndex}"
                    Value="{Binding CurrentStep, Mode=TwoWay}"
                    SmallChange="1" LargeChange="1"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"
                    ToolTip="Drag to jump to any step"/>
        </Border>

        <!-- ═══ Row 3 — Controls: step text left · nav centre · legend right ═ -->
        <Border Grid.Row="3" Background="{DynamicResource AssemblyCtrlBg}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- step description, left -->
                    <ColumnDefinition Width="Auto"/> <!-- playback buttons, centre -->
                    <ColumnDefinition Width="*"/>    <!-- legend, right -->
                </Grid.ColumnDefinitions>

                <!-- Step description — left -->
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextAccent}" FontSize="12"
                           FontFamily="Segoe UI" TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding StepDescription}"/>

                <!-- Playback controls — centre -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Style="{StaticResource CtrlBtn}"
                            Content="⏮"
                            Command="{Binding GoToStartCommand}"
                            ToolTip="Go to beginning (Step 1)"/>
                    <Button Style="{StaticResource CtrlBtn}"
                            Content="◀"
                            Command="{Binding PrevStepCommand}"
                            ToolTip="Previous step"/>
                    <Button Style="{StaticResource PlayBtn}"
                            Command="{Binding PlayPauseCommand}"
                            Content="{Binding PlayPauseLabel}"
                            ToolTip="Play / Pause auto-animation"/>
                    <Button Style="{StaticResource CtrlBtn}"
                            Content="▶"
                            Command="{Binding NextStepCommand}"
                            ToolTip="Next step"/>
                    <Button Style="{StaticResource CtrlBtn}"
                            Content="⏭"
                            Command="{Binding GoToEndCommand}"
                            ToolTip="Go to last step (fully assembled)"/>
                </StackPanel>

                <!-- Legend — right -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Style="{StaticResource LegendDot}" Fill="#ffcc30"/>
                    <TextBlock Text="Current" Foreground="{DynamicResource TextMuted}"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Ellipse Style="{StaticResource LegendDot}" Fill="#8098c8"/>
                    <TextBlock Text="Assembled" Foreground="{DynamicResource TextMuted}"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Ellipse Style="{StaticResource LegendDot}" Fill="#3355ff" Opacity="0.6"/>
                    <TextBlock Text="Upcoming" Foreground="{DynamicResource TextMuted}"
                               FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
